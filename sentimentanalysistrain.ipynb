import numpy as np
import pandas as pd
import matplotlib.pyplot as srh
import pickle
import re
from tensorflow.keras.preprocessing.sequence import pad_sequences
from tensorflow.keras.preprocessing.text import Tokenizer
from tensorflow.keras.layers import GRU,Dense,Embedding,Bidirectional,Dropout
from tensorflow.keras.callbacks import EarlyStopping,ModelCheckpoint
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import LabelEncoder
from tensorflow.keras.models import Sequential

#--------------Load dataset-------------------------------------------------------------------------------------------------------------------------


df=pd.read_csv(r"/content/IMDB Dataset.csv")
print(df.head())
print(df.shape)

#--------------------------------------Hyperparameters for the model--------------------------------------------------------------------


vocab=15000
maxlength=200
embedded=128
Gruunits=64
epochs=33
batchsize=64

print("missing values\n")
print(df.isnull().sum())
print(df["sentiment"].value_counts())

#------------- text cleaning function ------------------------------------------------------------------------------------------------------------------

def clean(text):
  text=text.lower()
  #removing html tags
  text=re.sub(r'<.*?','',text)
  #removing URLs
  text=re.sub(r'http\S+','',text)
  #removing special characters
  text=re.sub(r'[^a-zA-Z\s]','',text)
  #removing extra spaces
  text=re.sub(r'\s+','',text).strip()
  return text

#---------------------Applying cleaning the reviews-----------------------------------------------------------------------------------------


df["review"]=df["review"].apply(clean)
print(df["review"][0])
#----------------------------label encoding the sentiments-----------------------------------------------------------------------------


encoder=LabelEncoder()
df["sentiment"]=encoder.fit_transform(df["sentiment"])
print("Final result of preprocessing./n")
print(df.head())

x=df["review"]
y=df["sentiment"]

#--------------------------------tokenizer and padding------------------------------------------------------------------------------------------
tokenizer=Tokenizer(num_words=vocab,oov_token="<OOV>")
tokenizer.fit_on_texts(x)
wordindex=tokenizer.word_index
print("the number of words learnt:",len(wordindex))
sequencez=tokenizer.texts_to_sequences(x)
x_pad=pad_sequences(sequencez,
                     maxlen=maxlength,
                     padding="post",
                     truncating="post")
print("padded shape:/n")
print(x_pad.shape)


x_train,x_test,y_train,y_test=train_test_split(x_pad,y,test_size=0.2,random_state=42,stratify=y)
#---------------------------------------- Building the BiGRU model -----------------------------------------------------------------------

model=Sequential()
# Adding embedding
model.add(Embedding(
    input_dim=vocab,
    output_dim=embedded,
    input_length=maxlength
))
#
model.add(Bidirectional(GRU(
    Gruunits,
    dropout=0.3,
    recurrent_dropout=0.3
)))
model.add(Dense(64,activation="relu"))
model.add(Dropout(0.5))
model.add(Dense(1,activation="sigmoid"))

#------------------- Model compilation --------------------------------------------------------------------------------------------
model.compile(
    optimizer="adam",
    loss="binary_crossentropy",
    metrics=["accuracy"]
)
print("Model summary\n")
model.summary()

#---------------------------- callbacks and checkpoint -------------------------------------------------------------------------------------------------

stop=EarlyStopping(
    monitor="val_loss",
    patience=3,
    restore_best_weights=True,
)

checkpoint=ModelCheckpoint(filepath="sentiment_bigru.keras",
                           monitor="val_accuracy",
                           save_best_only=True)

#--------------------------- Training model and evaluation -------------------------------------------------------------------------------------------
history=model.fit(x_train,y_train,
          epochs=33,
          batch_size=64,
          validation_split=0.2,
          callbacks=[stop,checkpoint])

loss,accuracy=model.evaluate(x_test,y_test)
print("Test loss:",loss)
print("Model accuracy:",accuracy)

#------------------------------- Saving tokenizer and encoder -------------------------------------------------------------------------
model.save("sentiment_bigru.keras")
with open ("tokenizer.pkl","wb") as f:
  pickle.dump(tokenizer,f)
print("Tokenizer saved successfully")
with open("labelencoder.pkl","wb")  as file:
  pickle.dump(encoder,file)
print("Encoder saved succesfully")

#-------------------------- plotting the model accuracy and other metrics----------------------------------------------------------------
srh.figure(figsize=(8,5))
srh.plot(
    history.history["accuracy"],
    label="Training accuracy"
)
srh.plot(
    history.history["val_accuracy"],
    label="Validation accuracy"
)
srh.xlabel("epoch")
srh.ylabel("Accuracy")
srh.title("Training and validation accuracy")
srh.legend()
srh.grid(True)
srh.show()

srh.figure(figsize=(8,5))
srh.plot(
    history.history["loss"],
    label="Training loss"
)
srh.plot(
    history.history["val_loss"],
    label="Validation loss"
)
srh.xlabel("Epochs")
srh.ylabel("Loss")
srh.title("Training loss vs validation loss")
srh.legend()
srh.grid(True)
srh.show()

